{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Chatbot Settings"|t('chatagent') %}
{% set selectedSubnavItem = "settings" %}

{% block content %}
<div id="chatbot-settings">
    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ redirectInput('chatagent/settings') }}
        <input type="hidden" name="action" value="chatagent/logs/save-settings">

        <nav class="custom-tabs" style="display:flex; border-bottom: 2px solid #e3e5e8; margin-bottom: 24px; gap: 0;">
            <button type="button" class="custom-tab sel" data-target="tab-general">{{ "General"|t('chatagent') }}</button>
            <button type="button" class="custom-tab" data-target="tab-ai">{{ "AI Configuration"|t('chatagent') }}</button>
            <button type="button" class="custom-tab" data-target="tab-training">{{ "Training"|t('chatagent') }}</button>
            <button type="button" class="custom-tab" data-target="tab-suggestions">{{ "Suggestions"|t('chatagent') }}</button>
            <button type="button" class="custom-tab" data-target="tab-logging">{{ "Logging"|t('chatagent') }}</button>
        </nav>
        <style>
            .custom-tab { background: none; border: none; padding: 8px 16px; cursor: pointer; color: #8f98a3; font-size: 14px; border-bottom: 2px solid transparent; margin-bottom: -2px; }
            .custom-tab:hover { color: #3f4d5a; }
            .custom-tab.sel { color: #3f4d5a; border-bottom-color: #0d78f2; font-weight: 500; }
        </style>

        {# ── Tab: General ─────────────────────────────────────── #}
        <div id="tab-general">

            {{ forms.lightswitchField({
                label: "Enable chatbot"|t('chatagent'),
                instructions: "Shows the chat widget on the website."|t('chatagent'),
                id: 'enabled',
                name: 'enabled',
                on: settings.enabled,
            }) }}

            <hr>
            <h2>{{ "Appearance"|t('chatagent') }}</h2>

            {{ forms.textField({
                label: "Company Name (label)"|t('chatagent'),
                instructions: "Displayed in the chat window header."|t('chatagent'),
                id: 'companyName',
                name: 'companyName',
                value: settings.companyName,
            }) }}

            {{ forms.textField({
                label: "Logo Text (label)"|t('chatagent'),
                instructions: "Short text (max. 3 characters) in the logo badge."|t('chatagent'),
                id: 'logoText',
                name: 'logoText',
                value: settings.logoText,
                maxlength: 3,
                size: 5,
            }) }}

            {{ forms.elementSelectField({
                label: "Logo Image"|t('chatagent'),
                instructions: "Optional image instead of logo text. Recommended: square, min. 80×80 px."|t('chatagent'),
                id: 'logoAssetId',
                name: 'logoAssetId',
                elementType: 'craft\\elements\\Asset',
                limit: 1,
                elements: logoAsset ? [logoAsset] : [],
                criteria: { kind: 'image' },
            }) }}

            <div class="field">
                <div class="heading">
                    <label for="primaryColor">{{ "Primary Color"|t('chatagent') }}</label>
                    <div class="instructions"><p>{{ "Color for the chat button, send button, and user messages."|t('chatagent') }}</p></div>
                </div>
                <div class="input ltr flex" style="gap: 10px; align-items: center">
                    <input id="primaryColor" type="color" name="primaryColor" value="{{ settings.primaryColor }}"
                           oninput="document.getElementById('primaryColorHex').value = this.value">
                    <input id="primaryColorHex" class="nicetext code" type="text" maxlength="7"
                           style="width: 90px"
                           value="{{ settings.primaryColor }}"
                           placeholder="#7C3AED"
                           oninput="if(/^#[0-9A-Fa-f]{6}$/.test(this.value)) document.getElementById('primaryColor').value = this.value">
                </div>
            </div>

            <div class="field">
                <div class="heading">
                    <label for="logoBgColor">{{ "Logo background color"|t('chatagent') }}</label>
                    <div class="instructions"><p>{{ "Background color of the logo badge in the chat header."|t('chatagent') }}</p></div>
                </div>
                <div class="input ltr flex" style="gap: 10px; align-items: center">
                    <input id="logoBgColor" type="color" name="logoBgColor" value="{{ settings.logoBgColor ?? settings.primaryColor }}"
                           oninput="document.getElementById('logoBgColorHex').value = this.value">
                    <input id="logoBgColorHex" class="nicetext code" type="text" maxlength="7"
                           style="width: 90px"
                           value="{{ settings.logoBgColor ?? settings.primaryColor }}"
                           placeholder="#7C3AED"
                           oninput="if(/^#[0-9A-Fa-f]{6}$/.test(this.value)) document.getElementById('logoBgColor').value = this.value">
                </div>
            </div>

            {{ forms.selectField({
                label: "Default Theme"|t('chatagent'),
                instructions: "Light or dark design as default."|t('chatagent'),
                id: 'defaultTheme',
                name: 'defaultTheme',
                value: settings.defaultTheme,
                options: [
                    { label: "Light"|t('chatagent'), value: 'light' },
                    { label: "Dark"|t('chatagent'),  value: 'dark'  },
                ],
            }) }}

        </div>{# /tab-general #}

        {# ── Tab: AI Configuration ─────────────────────────────── #}
        <div id="tab-ai" class="hidden">

            {{ forms.textField({
                label: 'OpenAI API Key',
                instructions: "Used for embeddings and chat requests directly from Craft."|t('chatagent'),
                id: 'openaiApiKey',
                name: 'openaiApiKey',
                value: settings.openaiApiKey,
                type: 'password',
                placeholder: 'sk-...',
            }) }}

            {{ forms.selectField({
                label: "Chat Model"|t('chatagent'),
                instructions: "OpenAI model for chat responses."|t('chatagent'),
                id: 'openaiModel',
                name: 'openaiModel',
                value: settings.openaiModel,
                options: [
                    { label: 'gpt-4o-mini (recommended, affordable)', value: 'gpt-4o-mini' },
                    { label: 'gpt-4o (more capable)',                  value: 'gpt-4o'      },
                    { label: 'gpt-3.5-turbo (legacy)',                 value: 'gpt-3.5-turbo' },
                ],
            }) }}

            {{ forms.selectField({
                label: "Embedding Model"|t('chatagent'),
                instructions: "OpenAI model for vectorizing texts during training and search queries."|t('chatagent'),
                id: 'embeddingModel',
                name: 'embeddingModel',
                value: settings.embeddingModel,
                options: [
                    { label: 'text-embedding-3-small (recommended)', value: 'text-embedding-3-small' },
                    { label: 'text-embedding-3-large',                value: 'text-embedding-3-large' },
                    { label: 'text-embedding-ada-002 (legacy)',       value: 'text-embedding-ada-002' },
                ],
            }) }}

            <div class="pane" style="margin-top: -8px; margin-bottom: 16px; padding: 12px 16px; font-size: 13px; background: #f8f8f8;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 1px solid #e3e5e8;">
                            <th style="text-align: left; padding: 4px 8px 8px 0; color: #3f4d5a;">{{ "Model"|t('app') }}</th>
                            <th style="text-align: left; padding: 4px 8px 8px; color: #3f4d5a;">{{ "Dimensions"|t('chatagent') }}</th>
                            <th style="text-align: left; padding: 4px 8px 8px; color: #3f4d5a;">{{ "Cost"|t('chatagent') }}</th>
                            <th style="text-align: left; padding: 4px 0 8px; color: #3f4d5a;">{{ "Recommendation"|t('chatagent') }}</th>
                        </tr>
                    </thead>
                    <tbody style="color: #596673;">
                        <tr>
                            <td style="padding: 6px 8px 6px 0;"><code>text-embedding-3-small</code></td>
                            <td style="padding: 6px 8px;">1.536</td>
                            <td style="padding: 6px 8px;">$0.02 / 1M tokens</td>
                            <td style="padding: 6px 0;">{{ "Ideal for most use cases – fast, affordable"|t('chatagent') }}</td>
                        </tr>
                        <tr style="background: #f0f0f0;">
                            <td style="padding: 6px 8px 6px 0;"><code>text-embedding-3-large</code></td>
                            <td style="padding: 6px 8px;">3.072</td>
                            <td style="padding: 6px 8px;">$0.13 / 1M tokens</td>
                            <td style="padding: 6px 0;">{{ "Higher precision for complex texts – ~6× more expensive than small"|t('chatagent') }}</td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 8px 6px 0;"><code>text-embedding-ada-002</code></td>
                            <td style="padding: 6px 8px;">1.536</td>
                            <td style="padding: 6px 8px;">$0.10 / 1M tokens</td>
                            <td style="padding: 6px 0;">{{ "Older model – only use if already trained with it"|t('chatagent') }}</td>
                        </tr>
                    </tbody>
                </table>
                <p style="margin: 8px 0 0; color: #8f98a3; font-size: 12px;">⚠️ {{ "After switching models, the entire index must be retrained as vectors are not compatible."|t('chatagent') }}</p>
            </div>

            {{ forms.textField({
                label: "Initial Message"|t('chatagent'),
                instructions: "First message from the bot when opening the chat."|t('chatagent'),
                id: 'initialMessage',
                name: 'initialMessage',
                value: settings.initialMessage,
            }) }}

            {{ forms.textareaField({
                label: "System Prompt"|t('chatagent'),
                instructions: "Basic instructions for the AI assistant."|t('chatagent'),
                id: 'systemPrompt',
                name: 'systemPrompt',
                value: settings.systemPrompt,
                rows: 8,
                class: 'code',
            }) }}

            {{ forms.textField({
                label: "Max. Context Chunks"|t('chatagent'),
                instructions: "Maximum number of similar text sections passed as context to the AI."|t('chatagent'),
                id: 'maxContextChunks',
                name: 'maxContextChunks',
                value: settings.maxContextChunks,
                type: 'number',
                min: 1,
                max: 20,
                size: 5,
            }) }}

            {{ forms.textField({
                label: "Min. Similarity Score"|t('chatagent'),
                instructions: "Threshold (0.00–1.00) for cosine similarity. Lower values return more results but may be less relevant."|t('chatagent'),
                id: 'minSimilarityScore',
                name: 'minSimilarityScore',
                value: settings.minSimilarityScore,
                type: 'number',
                min: 0,
                max: 1,
                step: 0.05,
                size: 7,
            }) }}

        </div>{# /tab-ai #}

        {# ── Tab: Training ─────────────────────────────────────── #}
        <div id="tab-training" class="hidden">

            <div class="field">
                <div class="heading">
                    <label>{{ "Index Craft sections"|t('chatagent') }}</label>
                    <div class="instructions"><p>{{ "Select the sections whose content should be trained for the chatbot."|t('chatagent') }}</p></div>
                </div>
                <div class="input">
                    {% for section in allSections %}
                        <div style="margin-bottom: 6px">
                            <label>
                                <input type="checkbox"
                                       name="trainingSections[]"
                                       value="{{ section.handle }}"
                                       {% if section.handle in settings.trainingSections %}checked{% endif %}>
                                {{ section.name }}
                                <span class="code" style="font-size: 11px; color: #8f98a3">({{ section.handle }})</span>
                            </label>
                        </div>
                    {% endfor %}
                </div>
            </div>

            {{ forms.lightswitchField({
                label: "Auto-Train on Entry Save"|t('chatagent'),
                instructions: "Automatically indexes an entry when it is saved in the CP."|t('chatagent'),
                id: 'autoTrainOnSave',
                name: 'autoTrainOnSave',
                on: settings.autoTrainOnSave,
            }) }}

        </div>{# /tab-training #}

        {# ── Tab: Suggestions ──────────────────────────────────── #}
        <div id="tab-suggestions" class="hidden">

            {{ forms.lightswitchField({
                label: "Enable suggestions"|t('chatagent'),
                instructions: "Shows preset questions as buttons below the initial message in the chat widget."|t('chatagent'),
                id: 'suggestionsEnabled',
                name: 'suggestionsEnabled',
                on: settings.suggestionsEnabled ?? true,
            }) }}

            <div class="field">
                <div class="heading">
                    <label for="suggestions">{{ "Preset questions"|t('chatagent') }}</label>
                    <div class="instructions"><p>{{ "One question per line. Up to 4 questions are shown randomly. Empty lines are ignored."|t('chatagent') }}</p></div>
                </div>
                <div class="input">
                    <textarea id="suggestions" name="suggestions" rows="10"
                              class="nicetext code fullwidth"
                              style="border: 1px solid #d0d5dd; border-radius: 4px;">{{ settings.suggestions | default([]) | join('\n') }}</textarea>
                </div>
            </div>

        </div>{# /tab-suggestions #}

        {# ── Tab: Logging ──────────────────────────────────────── #}
        <div id="tab-logging" class="hidden">

            {{ forms.lightswitchField({
                label: "Enable message ratings"|t('chatagent'),
                instructions: "Shows thumbs up/down buttons below each bot response. Ratings are stored in the database and evaluated in the dashboard."|t('chatagent'),
                id: 'enableRatings',
                name: 'enableRatings',
                on: settings.enableRatings,
            }) }}

            {{ forms.lightswitchField({
                label: "Log Conversations"|t('chatagent'),
                instructions: "Stores all conversations in the database (visible under Chatbot → Logs)."|t('chatagent'),
                id: 'logConversations',
                name: 'logConversations',
                on: settings.logConversations,
            }) }}

            {{ forms.textField({
                label: "Log Retention (days, 0 = unlimited)"|t('chatagent'),
                instructions: "Automatically delete older sessions. 0 = keep indefinitely."|t('chatagent'),
                id: 'logRetentionDays',
                name: 'logRetentionDays',
                value: settings.logRetentionDays,
                type: 'number',
                min: 0,
                size: 8,
            }) }}

        </div>{# /tab-logging #}

        <div class="btngroup" style="margin-top: 24px">
            <button type="submit" class="btn submit">{{ "Save settings"|t('chatagent') }}</button>
        </div>
    </form>
</div>

<script>
(function () {
    var tabs   = document.querySelectorAll('.custom-tab');
    var panels = ['tab-general', 'tab-ai', 'tab-training', 'tab-suggestions', 'tab-logging'];

    tabs.forEach(function(btn) {
        btn.addEventListener('click', function() {
            tabs.forEach(function(t) { t.classList.remove('sel'); });
            panels.forEach(function(id) {
                var el = document.getElementById(id);
                if (el) el.classList.add('hidden');
            });
            btn.classList.add('sel');
            var target = document.getElementById(btn.dataset.target);
            if (target) target.classList.remove('hidden');
        });
    });
})();
</script>

{% endblock %}
